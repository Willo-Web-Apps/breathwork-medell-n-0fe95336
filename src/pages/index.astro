---
import Base from '../layouts/Base.astro';
---
<Base
  title="Aliento — 5D Breathwork in Medellín"
  description="Premium 5D Breathwork coaching in Medellín. Private sessions and group Reset experiences at Nordika's rooftop wellness space in Ciudad del Río. For expats, digital nomads, and locals ready for profound clarity."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO — Immersive atmospheric, storytelling feel
  ═══════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden grain-overlay" style="background: oklch(0.13 0.04 35);">

    <!-- Layered atmospheric gradient — Medellín afternoon light -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 90% 70% at 15% 90%, oklch(0.43 0.13 30 / 0.55) 0%, transparent 65%),
        radial-gradient(ellipse 70% 60% at 85% 10%, oklch(0.63 0.13 65 / 0.30) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 60% 60%, oklch(0.52 0.10 45 / 0.18) 0%, transparent 55%),
        linear-gradient(168deg, oklch(0.11 0.03 35) 0%, oklch(0.16 0.05 38) 50%, oklch(0.20 0.06 40) 100%);
    "></div>

    <!-- Fade to dark at very bottom to blend with next section -->
    <div class="absolute bottom-0 left-0 right-0 h-40" style="background: linear-gradient(to bottom, transparent, oklch(0.13 0.04 35));"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 sm:px-10 lg:px-12 py-32 md:py-40">

      <!-- Eyebrow -->
      <div class="animate-fade-in mb-8 flex items-center gap-3">
        <span class="rule-gold"></span>
        <span class="text-accent-400 font-body text-xs font-500 tracking-[0.2em] uppercase" style="color: oklch(0.75 0.11 65);">Medellín · Colombia</span>
      </div>

      <!-- Main headline -->
      <h1 class="animate-slide-up font-display font-300 leading-[1.05] tracking-tight"
          style="font-size: clamp(2.8rem, 7vw, 6rem); color: oklch(0.95 0.015 68);">
        Your Most Profound<br/>
        <em class="font-300 italic" style="color: oklch(0.75 0.11 65);">Reset</em> Starts With<br/>
        One Breath
      </h1>

      <!-- Sub -->
      <p class="animate-slide-up delay-200 mt-8 font-body font-300 leading-relaxed max-w-xl"
         style="font-size: 1.125rem; color: oklch(0.80 0.02 65);">
        5D Breathwork coaching in Medellín — private sessions and group
        Reset experiences at Nordika's rooftop, Ciudad del Río.
      </p>

      <!-- CTAs -->
      <div class="animate-slide-up delay-300 mt-12 flex flex-col sm:flex-row gap-4">
        <a
          href="https://www.instagram.com/5dbreathworka"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 font-body font-500 text-sm tracking-wide transition-all duration-200 hover:scale-[1.03]"
          style="background: oklch(0.43 0.13 30); color: oklch(0.97 0.01 70); border-radius: 2px; letter-spacing: 0.05em; text-transform: uppercase;"
        >
          Book a Private Session
        </a>
        <a
          href="#reset"
          class="inline-flex items-center justify-center px-8 py-4 font-body font-500 text-sm tracking-wide transition-all duration-200 hover:scale-[1.03]"
          style="background: transparent; color: oklch(0.75 0.11 65); border: 1px solid oklch(0.63 0.13 65 / 0.5); border-radius: 2px; letter-spacing: 0.05em; text-transform: uppercase;"
        >
          Join the Next Reset
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
      </div>

      <!-- Micro proof -->
      <p class="animate-fade-in delay-400 mt-8 font-body font-300 text-xs tracking-widest uppercase"
         style="color: oklch(0.55 0.03 50);">
        Sessions held in English &amp; Spanish
      </p>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-breathe">
      <span class="font-body text-xs tracking-[0.25em] uppercase" style="color: oklch(0.50 0.04 50);">Inhale</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" style="color: oklch(0.50 0.04 50);">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       ORIGIN STORY — Who is Aliento? What is 5D Breathwork?
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 md:py-36" style="background: oklch(0.95 0.018 68);">
    <div class="max-w-4xl mx-auto px-6 sm:px-10">

      <!-- Overline -->
      <div class="flex items-center gap-3 mb-10">
        <span class="rule-gold"></span>
        <span class="font-body text-xs font-500 tracking-[0.2em] uppercase" style="color: oklch(0.43 0.13 30);">The Practice</span>
      </div>

      <!-- Large editorial headline -->
      <h2 class="font-display font-300 leading-[1.12] mb-10"
          style="font-size: clamp(2.2rem, 5vw, 4rem); color: oklch(0.22 0.04 38);">
        Not yoga. Not meditation.<br/>
        <em class="italic font-300" style="color: oklch(0.43 0.13 30);">Something far more alive.</em>
      </h2>

      <div class="grid md:grid-cols-2 gap-12 md:gap-20">
        <div>
          <p class="font-body font-300 leading-[1.85] mb-6" style="font-size: 1.0625rem; color: oklch(0.30 0.03 40);">
            5D Breathwork is an active, conscious breathing practice that bypasses the thinking mind and goes directly to the body — unlocking emotional blockages, flooding your system with oxygen, and opening access to states of clarity and aliveness that most people never touch.
          </p>
          <p class="font-body font-300 leading-[1.85]" style="font-size: 1.0625rem; color: oklch(0.30 0.03 40);">
            No substances. No guesswork. Just breath — guided with expertise and care, here in the heart of Medellín.
          </p>
        </div>
        <div>
          <p class="font-body font-300 leading-[1.85] mb-6" style="font-size: 1.0625rem; color: oklch(0.30 0.03 40);">
            <strong class="font-500" style="color: oklch(0.22 0.04 38);">Aliento</strong> — the Spanish word for breath, for life-force — was built for English-speaking expats, digital nomads, and Medellín locals who sense that something deeper is available to them, and are ready to reach for it.
          </p>
          <p class="font-body font-300 leading-[1.85]" style="font-size: 1.0625rem; color: oklch(0.30 0.03 40);">
            Every session is held in English and Spanish, in a space of genuine warmth and zero judgment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       PULL QUOTE — Editorial breath moment
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 overflow-hidden" style="background: oklch(0.91 0.022 66);">
    <div class="max-w-4xl mx-auto px-6 sm:px-10 text-center">
      <!-- Decorative large quote mark -->
      <div class="font-display font-600 italic leading-none mb-2 select-none"
           style="font-size: clamp(5rem, 12vw, 9rem); color: oklch(0.63 0.13 65 / 0.20); line-height: 0.7; margin-bottom: 1rem;">
        &ldquo;
      </div>
      <blockquote
        class="font-display font-300 italic leading-[1.2]"
        style="font-size: clamp(1.75rem, 4.5vw, 3.25rem); color: oklch(0.22 0.04 38);">
        One session can move what years of&nbsp;therapy hasn't&nbsp;touched.
      </blockquote>
      <div class="mt-8 flex items-center justify-center gap-4">
        <span class="rule-gold"></span>
        <p class="font-body font-300 text-xs tracking-widest uppercase" style="color: oklch(0.50 0.05 40);">Aliento client · Medellín</p>
        <span class="rule-gold"></span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       VALUES / PRINCIPLES — 3 pillars, visual anchors
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 md:py-36" style="background: oklch(0.95 0.018 68);">
    <div class="max-w-5xl mx-auto px-6 sm:px-10">

      <div class="flex items-center gap-3 mb-16">
        <span class="rule-gold"></span>
        <span class="font-body text-xs font-500 tracking-[0.2em] uppercase" style="color: oklch(0.43 0.13 30);">What You'll Find Here</span>
      </div>

      <div class="grid md:grid-cols-3 gap-12 md:gap-8">

        <!-- Pillar 1 -->
        <div>
          <div class="font-display font-300 mb-4" style="font-size: 4rem; line-height: 1; color: oklch(0.63 0.13 65 / 0.35);">01</div>
          <h3 class="font-display font-600 mb-4" style="font-size: 1.5rem; color: oklch(0.22 0.04 38);">Genuine Expertise</h3>
          <p class="font-body font-300 leading-relaxed" style="font-size: 1rem; color: oklch(0.35 0.03 40);">
            Trained in 5D Breathwork methods with a deep understanding of the nervous system. Each session is held with care, structure, and real skill — never improvised.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div>
          <div class="font-display font-300 mb-4" style="font-size: 4rem; line-height: 1; color: oklch(0.63 0.13 65 / 0.35);">02</div>
          <h3 class="font-display font-600 mb-4" style="font-size: 1.5rem; color: oklch(0.22 0.04 38);">No Pretense</h3>
          <p class="font-body font-300 leading-relaxed" style="font-size: 1rem; color: oklch(0.35 0.03 40);">
            No spiritual bypassing. No pressure to believe anything. Just an honest, evidence-informed practice that works with your body exactly as it is today.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div>
          <div class="font-display font-300 mb-4" style="font-size: 4rem; line-height: 1; color: oklch(0.63 0.13 65 / 0.35);">03</div>
          <h3 class="font-display font-600 mb-4" style="font-size: 1.5rem; color: oklch(0.22 0.04 38);">Real Results</h3>
          <p class="font-body font-300 leading-relaxed" style="font-size: 1rem; color: oklch(0.35 0.03 40);">
            Clients leave with measurable calm, emotional release, or peak clarity — not a vague "good vibes" feeling. The practice meets you where you are and takes you further.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       PRIVATE SESSIONS — Intimate, personal
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 md:py-36 overflow-hidden" style="background: oklch(0.97 0.012 70);">
    <div class="max-w-5xl mx-auto px-6 sm:px-10">

      <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">

        <!-- Text -->
        <div>
          <div class="flex items-center gap-3 mb-8">
            <span class="rule-gold"></span>
            <span class="font-body text-xs font-500 tracking-[0.2em] uppercase" style="color: oklch(0.43 0.13 30);">Individual Coaching</span>
          </div>

          <h2 class="font-display font-300 leading-[1.1] mb-8"
              style="font-size: clamp(2rem, 4.5vw, 3.25rem); color: oklch(0.22 0.04 38);">
            A private session,<br/>
            <em class="italic" style="color: oklch(0.43 0.13 30);">designed for you.</em>
          </h2>

          <p class="font-body font-300 leading-relaxed mb-6" style="font-size: 1.0625rem; color: oklch(0.30 0.03 40);">
            Individual sessions are for people who want to go deep — nervous system regulation, emotional processing, creative breakthroughs, or simply a profound reset from the pace of modern life.
          </p>
          <p class="font-body font-300 leading-relaxed mb-10" style="font-size: 1.0625rem; color: oklch(0.30 0.03 40);">
            We begin with a conversation. The session is shaped entirely around you — your body, your history, what you're ready to move. This is not a template. It's tailored breath coaching.
          </p>

          <a
            href="https://www.instagram.com/5dbreathworka"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 font-body font-500 text-sm tracking-wide transition-all duration-200 hover:gap-5 group"
            style="color: oklch(0.43 0.13 30); letter-spacing: 0.05em; text-transform: uppercase;"
          >
            Book a Private Session
            <svg class="w-5 h-5 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>

        <!-- Visual card -->
        <div class="relative">
          <div class="relative rounded-sm overflow-hidden" style="aspect-ratio: 4/5; background: linear-gradient(155deg, oklch(0.43 0.13 30 / 0.12) 0%, oklch(0.63 0.13 65 / 0.08) 100%); border: 1px solid oklch(0.63 0.13 65 / 0.2);">

            <!-- Inner content -->
            <div class="absolute inset-0 flex flex-col justify-end p-8"
                 style="background: linear-gradient(to top, oklch(0.22 0.04 38 / 0.7) 0%, transparent 60%);">
              <p class="font-display font-300 italic leading-snug mb-3"
                 style="font-size: 1.5rem; color: oklch(0.95 0.015 68);">
                "I came in carrying months of burnout. I left lighter."
              </p>
              <p class="font-body font-300 text-xs tracking-widest uppercase"
                 style="color: oklch(0.75 0.11 65);">Digital nomad, Medellín</p>
            </div>

            <!-- Decorative elements -->
            <div class="absolute top-8 right-8">
              <div class="w-16 h-16 rounded-full animate-breathe"
                   style="border: 1px solid oklch(0.63 0.13 65 / 0.4);"></div>
            </div>
            <div class="absolute top-16 right-16">
              <div class="w-8 h-8 rounded-full animate-breathe"
                   style="border: 1px solid oklch(0.63 0.13 65 / 0.25); animation-delay: 2s;"></div>
            </div>
          </div>

          <!-- Offset accent block -->
          <div class="absolute -bottom-6 -left-6 w-24 h-24 -z-10"
               style="background: oklch(0.43 0.13 30 / 0.15); border-radius: 2px;"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       NORDIKA RESET — The group experience, rooftop Medellín
  ═══════════════════════════════════════════════════════════════ -->
  <section id="reset" class="relative py-28 md:py-40 overflow-hidden grain-overlay" style="background: oklch(0.13 0.04 35);">

    <!-- Atmospheric gradient -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 80% 60% at 80% 20%, oklch(0.63 0.13 65 / 0.25) 0%, transparent 60%),
        radial-gradient(ellipse 70% 70% at 10% 80%, oklch(0.43 0.13 30 / 0.40) 0%, transparent 60%),
        linear-gradient(160deg, oklch(0.11 0.03 35) 0%, oklch(0.18 0.05 38) 100%);
    "></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 sm:px-10">

      <div class="flex items-center gap-3 mb-12">
        <span class="rule-gold"></span>
        <span class="font-body text-xs font-500 tracking-[0.2em] uppercase" style="color: oklch(0.75 0.11 65);">Group Experience · Nordika, Ciudad del Río</span>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-start">

        <!-- Headline + text -->
        <div>
          <h2 class="font-display font-300 leading-[1.1] mb-8"
              style="font-size: clamp(2rem, 4.5vw, 3.5rem); color: oklch(0.95 0.015 68);">
            The Reset Session.<br/>
            <em class="italic font-300" style="color: oklch(0.75 0.11 65);">Rooftop. Alive.</em>
          </h2>

          <p class="font-body font-300 leading-relaxed mb-6" style="font-size: 1.0625rem; color: oklch(0.75 0.02 60);">
            Held at <strong class="font-500" style="color: oklch(0.90 0.02 65);">Nordika</strong> — Medellín's rooftop wellness sanctuary in Ciudad del Río — the Reset Session combines guided 5D Breathwork with the full thermal contrast experience: sauna, cold plunge, jacuzzi, and open city views.
          </p>

          <p class="font-body font-300 leading-relaxed mb-10" style="font-size: 1.0625rem; color: oklch(0.75 0.02 60);">
            The group format creates something that a solo session can't — a shared field of intention. You'll breathe alongside others who showed up, same as you. The result is often more powerful than anything you'd expect.
          </p>

          <a
            href="https://www.instagram.com/5dbreathworka"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 font-body font-500 text-sm tracking-wide transition-all duration-200 hover:scale-[1.03]"
            style="background: oklch(0.63 0.13 65); color: oklch(0.13 0.04 35); border-radius: 2px; letter-spacing: 0.05em; text-transform: uppercase;"
          >
            Join the Next Reset
          </a>
        </div>

        <!-- What's included card -->
        <div>
          <div class="p-8 md:p-10 rounded-sm"
               style="background: oklch(0.95 0.018 68 / 0.07); border: 1px solid oklch(0.75 0.11 65 / 0.2); backdrop-filter: blur(16px);">

            <h3 class="font-display font-600 mb-8"
                style="font-size: 1.25rem; color: oklch(0.90 0.02 68); letter-spacing: 0.01em;">
              What's included
            </h3>

            <ul class="space-y-5">
              {[
                ["Guided 5D Breathwork", "60 min active breathwork session, full instruction provided"],
                ["Sauna", "Thermal preparation to open the body before breathwork"],
                ["Cold Plunge", "Contrast therapy for nervous system activation"],
                ["Jacuzzi", "Integration and relaxation after the journey"],
                ["City Views", "Nordika rooftop, Ciudad del Río — Medellín at its most alive"],
                ["English & Spanish", "All guidance available in both languages"],
              ].map(([title, desc]) => (
                <li class="flex gap-4 items-start">
                  <span class="mt-1 shrink-0 w-1.5 h-1.5 rounded-full" style="background: oklch(0.63 0.13 65); margin-top: 7px;"></span>
                  <div>
                    <span class="font-body font-500 text-sm" style="color: oklch(0.90 0.02 68);">{title}</span>
                    <p class="font-body font-300 text-sm mt-0.5" style="color: oklch(0.65 0.02 55);">{desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       WHO THIS IS FOR — Target audience resonance
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-28 md:py-36" style="background: oklch(0.91 0.022 66);">
    <div class="max-w-4xl mx-auto px-6 sm:px-10">

      <div class="flex items-center gap-3 mb-12">
        <span class="rule-gold"></span>
        <span class="font-body text-xs font-500 tracking-[0.2em] uppercase" style="color: oklch(0.43 0.13 30);">Who This Is For</span>
      </div>

      <h2 class="font-display font-300 leading-[1.12] mb-14"
          style="font-size: clamp(1.8rem, 4vw, 3rem); color: oklch(0.22 0.04 38);">
        You don't need to have tried breathwork before.<br/>
        <em class="italic" style="color: oklch(0.43 0.13 30);">You just need to be ready.</em>
      </h2>

      <div class="grid sm:grid-cols-2 gap-8">

        {[
          {
            label: "Expats & Digital Nomads",
            text: "Living in Medellín and feeling the weight of constant change, decision fatigue, or that low hum of disconnection. You want to feel grounded — really grounded — in your body."
          },
          {
            label: "High Performers",
            text: "Entrepreneurs, remote founders, and creatives who've noticed that the usual tools — cold showers, journaling, meditation — are no longer moving the needle."
          },
          {
            label: "Emotional Processors",
            text: "You've done therapy. You know yourself. But there's something still stuck — in the chest, in the gut — that words haven't reached. This practice reaches it."
          },
          {
            label: "Curious Locals",
            text: "Colombian residents open to somatic, premium wellness experiences. You're not looking for a trend. You're looking for something real."
          },
        ].map(({ label, text }) => (
          <div class="p-8 rounded-sm" style="background: oklch(0.95 0.018 68); border: 1px solid oklch(0.63 0.13 65 / 0.15);">
            <h3 class="font-display font-600 mb-3" style="font-size: 1.25rem; color: oklch(0.22 0.04 38);">{label}</h3>
            <p class="font-body font-300 leading-relaxed text-sm" style="color: oklch(0.35 0.03 40);">{text}</p>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FINAL CTA — Mission-driven, warm close
  ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-32 md:py-44 overflow-hidden grain-overlay" style="background: oklch(0.22 0.04 38);">

    <!-- Atmospheric warm glow -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 70% 80% at 50% 110%, oklch(0.43 0.13 30 / 0.50) 0%, transparent 60%),
        radial-gradient(ellipse 50% 50% at 80% 0%, oklch(0.63 0.13 65 / 0.20) 0%, transparent 55%);
    "></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 sm:px-10 text-center">

      <div class="flex justify-center mb-8">
        <span class="rule-gold mx-auto"></span>
      </div>

      <h2 class="font-display font-300 leading-[1.1] mb-8"
          style="font-size: clamp(2.2rem, 5vw, 4rem); color: oklch(0.95 0.015 68);">
        Medellín is alive.<br/>
        <em class="italic font-300" style="color: oklch(0.75 0.11 65);">Are you?</em>
      </h2>

      <p class="font-body font-300 leading-relaxed mb-12 max-w-xl mx-auto" style="font-size: 1.0625rem; color: oklch(0.72 0.02 55);">
        Whether you book a private session or join the next Reset at Nordika — the first breath is the one that changes everything. Reach out on Instagram or send a message to get started.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://www.instagram.com/5dbreathworka"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 font-body font-500 text-sm tracking-wide transition-all duration-200 hover:scale-[1.03]"
          style="background: oklch(0.43 0.13 30); color: oklch(0.97 0.01 70); border-radius: 2px; letter-spacing: 0.05em; text-transform: uppercase;"
        >
          Book a Private Session
        </a>
        <a
          href="https://www.instagram.com/5dbreathworka"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 font-body font-500 text-sm tracking-wide transition-all duration-200 hover:scale-[1.03]"
          style="background: oklch(0.63 0.13 65); color: oklch(0.13 0.04 35); border-radius: 2px; letter-spacing: 0.05em; text-transform: uppercase;"
