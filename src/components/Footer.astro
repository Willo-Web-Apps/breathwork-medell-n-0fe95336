---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.14 0.03 35); border-top: 1px solid oklch(0.75 0.11 65 / 0.1);">
  <div class="max-w-5xl mx-auto px-6 sm:px-10 py-14">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">

      <!-- Brand -->
      <div>
        <p class="font-display font-600 mb-2" style="font-size: 1.75rem; color: oklch(0.95 0.015 68); letter-spacing: -0.01em;">
          Aliento
        </p>
        <p class="font-body font-300 text-xs tracking-widest uppercase" style="color: oklch(0.50 0.04 50);">
          Breathe Deeper. Live Freer.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-6 sm:items-center">

        <a
          href="https://www.instagram.com/5dbreathworka"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-body font-400 text-xs tracking-[0.15em] uppercase transition-opacity duration-150 hover:opacity-60"
          style="color: oklch(0.75 0.11 65);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @5dbreathworka
        </a>

        <span class="hidden sm:block" style="color: oklch(0.30 0.02 40);">·</span>

        <span class="font-body font-300 text-xs tracking-widest uppercase" style="color: oklch(0.40 0.03 45);">
          Nordika · Ciudad del Río · Medellín
        </span>

      </div>
    </div>

    <!-- Divider -->
    <div class="mt-10 pt-8" style="border-top: 1px solid oklch(0.75 0.11 65 / 0.08);">
      <p class="font-body font-300 text-xs" style="color: oklch(0.35 0.02 40);">
        &copy; {year} Aliento. 5D Breathwork Medellín. All rights reserved.
      </p>
    </div>

  </div>
</footer>
