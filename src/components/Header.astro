<style>
  .nav-link {
    color: oklch(0.40 0.04 40);
    transition: color 0.15s ease;
  }
  .nav-link:hover {
    color: oklch(0.43 0.13 30);
  }
  /* Transparent header when over dark hero — becomes opaque on scroll */
  .site-header {
    background: oklch(0.97 0.012 70 / 0.92);
    border-bottom: 1px solid oklch(0.63 0.13 65 / 0.15);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
  }
</style>

<header class="site-header sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-6 sm:px-10 h-16 flex items-center justify-between">

    <!-- Wordmark -->
    <a href="/"
       class="font-display tracking-tight transition-opacity duration-150 hover:opacity-70"
       style="font-size: 1.5rem; font-weight: 600; color: oklch(0.22 0.04 38); letter-spacing: -0.015em;">
      Aliento
    </a>

    <!-- Navigation -->
    <div class="flex items-center gap-7">
      <a href="#reset" class="nav-link hidden sm:block font-body text-xs font-400 tracking-[0.15em] uppercase">
        Reset Sessions
      </a>
      <a href="#reset" class="nav-link hidden md:block font-body text-xs font-400 tracking-[0.15em] uppercase">
        Private Sessions
      </a>
      <a
        href="https://www.instagram.com/5dbreathworka"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-body font-500 text-xs tracking-[0.12em] uppercase px-5 py-2.5 transition-opacity duration-200 hover:opacity-80"
        style="background: oklch(0.43 0.13 30); color: oklch(0.97 0.01 70); border-radius: 2px; min-height: 44px;"
      >
        <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
